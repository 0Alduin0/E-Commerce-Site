# Backend ortam değişkenleri ÖRNEĞİ — bu dosya git'e commit EDİLİR.
# Gerçek değerleri .env dosyasına yaz; .env asla commit edilmez.

PROJECT_NAME=E-Ticaret API
ENVIRONMENT=development

# CORS: izinli frontend adresi. Birden fazlaysa virgülle ayır.
# Production'da gerçek Vercel/domain adresi yazılır.
FRONTEND_URL=http://localhost:3000

