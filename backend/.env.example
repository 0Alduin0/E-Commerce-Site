# Backend ortam değişkenleri ÖRNEĞİ — bu dosya git'e commit EDİLİR.
# Gerçek değerleri .env dosyasına yaz; .env asla commit edilmez.

PROJECT_NAME=E-Ticaret API
# development | production. Production'da cookie'ler Secure (HTTPS) işaretlenir.
ENVIRONMENT=development

# --- Veritabanı (Faz 9) ---
# Dev: boş bırak → SQLite (sqlite:///./ecommerce.db) kullanılır, sürücü gerekmez.
# Prod: Railway PostgreSQL bağlantı dizesi. psycopg3 için şema "postgresql+psycopg://".
# Railway sana "postgresql://..." verir; başına "+psycopg" eklemen GEREKİR:
#   postgresql+psycopg://user:pass@host:5432/railway
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# CORS: izinli frontend adresi. Birden fazlaysa virgülle ayır.
# Production'da gerçek Vercel/domain adresi (sonunda / yok): https://magaza.vercel.app
FRONTEND_URL=http://localhost:3000

# --- JWT auth (Faz 3) ---
# Production'da MUTLAKA değiştir. Üret: python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Refresh cookie SameSite. Dev: lax. Prod'da frontend (Vercel) ile backend (Railway)
# AYRI domain olduğundan "none" yap (yoksa oturum yenileme cross-site çalışmaz).
COOKIE_SAMESITE=lax

# --- Cloudflare R2 / görsel yükleme (Faz 5) ---
# Hepsi dolu olmadan görsel yükleme uçları 503 döner (backend yine çalışır).
# Cloudflare dashboard → R2 → bucket oluştur → API token (Access Key) al.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Görsellerin tarayıcıdan erişileceği taban URL (public bucket veya cdn.site.com), sonunda / yok
R2_PUBLIC_BASE_URL=
# Limitler (opsiyonel — varsayılanlar config.py'de)
MAX_IMAGE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# --- Ödeme / İyzico (Faz 8) ---
# Boşsa ödeme uçları 503 döner (backend yine ayakta). İyzico sandbox panelinden al.
PAYMENT_PROVIDER=iyzico
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# İyzico ödeme sonrası tarayıcıyı POST'layacağı adres = BACKEND callback ucu
# (Next.js sayfası POST kabul etmez → 405). Prod örn:
#   https://api.magaza.up.railway.app/payments/callback
PAYMENT_CALLBACK_URL=http://localhost:8000/payments/callback
# Kullanıcının ödeme sonrası göreceği FRONTEND sonuç sayfası (callback buraya yollar)
# Prod örn: https://magaza.vercel.app/odeme/sonuc
PAYMENT_RESULT_URL=http://localhost:3000/odeme/sonuc
# İyzico panelinde webhook URL'i: {BACKEND}/payments/webhook olarak ayarlanır
# (prod örn: https://api.magaza.up.railway.app/payments/webhook)
