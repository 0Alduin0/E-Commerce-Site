# Frontend ortam değişkenleri ÖRNEĞİ — bu dosya git'e commit EDİLİR.
# Gerçek değerleri .env.local dosyasına yaz; .env.local asla commit edilmez.

# Backend API adresi. Production'da gerçek Railway adresi (sonunda / yok):
#   https://api.magaza.up.railway.app
# Vercel panelinde Environment Variables bölümüne girilir (NEXT_PUBLIC_ → build'e gömülür).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Ürün görsellerinin host'u (next/image whitelist'i için). Sadece alan adı, şema/yol yok.
# Örn. cdn.site.com  ya da  <account_id>.r2.cloudflarestorage.com
# Boş bırakılırsa görseller placeholder ile gösterilir (görsel henüz yüklenmemişse).
NEXT_PUBLIC_IMAGE_HOST=
